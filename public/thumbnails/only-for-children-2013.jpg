<style>
.compact-social-bar {
    display: inline-flex;
    align-items: center;
    gap: 14px; /* Puțin mai mult spațiu pentru claritate */
    background: rgba(255, 255, 255, 0.5); /* Efect de pastilă discretă */
    padding: 8px 16px;
    border-radius: 30px;
    border: 1px solid rgba(0,0,0,0.06);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
}

.mini-icon {
    color: #3a3a3c; /* Gri închis Apple */
    text-decoration: none;
    line-height: 0;
    transition: all 0.2s ease;
}

.mini-icon svg {
    width: 16px; /* Mărime optimă pentru mobil și desktop */
    height: 16px;
    display: block;
}

.mini-icon:hover {
    color: #000;
    transform: scale(1.15);
}

/* Dark Mode Support automat */
@media (prefers-color-scheme: dark) {
    .compact-social-bar {
        background: rgba(255, 255, 255, 0.1);
        border: 1px solid rgba(255,255,255,0.1);
    }
    .mini-icon { color: #d1d1d6; }
    .mini-icon:hover { color: #fff; }
}
