							<div class="elementor-shortcode">
<style>
#catmenu_470b45b3-8e16-48a2-b5b2-e813f12e05b9{margin:.25rem 0 1rem;font-family:'Sora',system-ui}
#catmenu_470b45b3-8e16-48a2-b5b2-e813f12e05b9 .cat-inline-menu-wrap{position:relative;width:100%}
#catmenu_470b45b3-8e16-48a2-b5b2-e813f12e05b9 .cat-inline-menu{
  display:flex;gap:.5rem;flex-wrap:nowrap;overflow-x:auto;
  -webkit-overflow-scrolling:touch;scroll-snap-type:x proximity;
  padding:.25rem .5rem;margin:0;list-style:none;scrollbar-width:none;scroll-behavior:smooth
}
#catmenu_470b45b3-8e16-48a2-b5b2-e813f12e05b9 .cat-inline-menu::-webkit-scrollbar{display:none}

/* fade edges */
#catmenu_470b45b3-8e16-48a2-b5b2-e813f12e05b9 .fade-edge{
  position:absolute;top:0;bottom:0;width:48px;pointer-events:none;transition:.2s;
  background:linear-gradient(90deg,#fff,rgba(255,255,255,0));opacity:1
}
#catmenu_470b45b3-8e16-48a2-b5b2-e813f12e05b9 .fade-left{left:0}
#catmenu_470b45b3-8e16-48a2-b5b2-e813f12e05b9 .fade-right{right:0;transform:scaleX(-1)}
#catmenu_470b45b3-8e16-48a2-b5b2-e813f12e05b9.no-overflow .fade-edge{opacity:0}
#catmenu_470b45b3-8e16-48a2-b5b2-e813f12e05b9.at-start .fade-left{opacity:0}
#catmenu_470b45b3-8e16-48a2-b5b2-e813f12e05b9.at-end .fade-right{opacity:0}

/* chips */
#catmenu_470b45b3-8e16-48a2-b5b2-e813f12e05b9 .cat-chip{
  scroll-snap-align:start;display:inline-flex;align-items:center;justify-content:center;
  padding:.55rem .9rem;background:#fff;border:2px solid #000;border-radius:12px;
  text-decoration:none;color:#000;font-weight:900;text-transform:uppercase;white-space:nowrap;
  transition:.12s;user-select:none
}
#catmenu_470b45b3-8e16-48a2-b5b2-e813f12e05b9 .cat-chip:hover{transform:translateY(-1px);box-shadow:0 2px 0 #000}
#catmenu_470b45b3-8e16-48a2-b5b2-e813f12e05b9 .cat-chip.is-active{background:#000;color:#fff}

/* mobile drag cursor */
@media(max-width:991.98px){
  #catmenu_470b45b3-8e16-48a2-b5b2-e813f12e05b9 .cat-inline-menu{cursor:grab}
  #catmenu_470b45b3-8e16-48a2-b5b2-e813f12e05b9.dragging .cat-inline-menu{cursor:grabbing}
}

/* arrows (inside); LEFT is hidden at start; shows only after scrolling right */
#catmenu_470b45b3-8e16-48a2-b5b2-e813f12e05b9 .nav-btn{
  position:absolute;top:50%;transform:translateY(-50%);
  width:36px;height:36px;border-radius:10px;border:2px solid #000;background:#fff;
  display:none;align-items:center;justify-content:center;font-weight:900;line-height:1;color:#000;
  box-shadow:0 2px 0 #000;cursor:pointer;transition:transform .12s ease,opacity .12s ease;z-index:3
}
#catmenu_470b45b3-8e16-48a2-b5b2-e813f12e05b9 .nav-btn:hover{transform:translateY(-50%) scale(1.03)}
#catmenu_470b45b3-8e16-48a2-b5b2-e813f12e05b9 .nav-left{left:6px}
#catmenu_470b45b3-8e16-48a2-b5b2-e813f12e05b9 .nav-right{right:6px}
@media(min-width:992px){
  #catmenu_470b45b3-8e16-48a2-b5b2-e813f12e05b9 .nav-right{display:inline-flex} /* right arrow is available on desktop when overflow */
}
#catmenu_470b45b3-8e16-48a2-b5b2-e813f12e05b9.no-overflow .nav-btn{display:none}
#catmenu_470b45b3-8e16-48a2-b5b2-e813f12e05b9.at-end .nav-right{opacity:0;pointer-events:none}

/* When LEFT should be visible (after you scrolled right), show it AND add left padding so it never overlaps */
@media(min-width:992px){
  #catmenu_470b45b3-8e16-48a2-b5b2-e813f12e05b9.left-visible .nav-left{display:inline-flex}
  #catmenu_470b45b3-8e16-48a2-b5b2-e813f12e05b9.left-visible .cat-inline-menu{padding-left:56px}
  #catmenu_470b45b3-8e16-48a2-b5b2-e813f12e05b9.left-visible .fade-left{left:56px}
}
</style>

<nav id="catmenu_470b45b3-8e16-48a2-b5b2-e813f12e05b9" class="cat-inline-menu-component" aria-label="Categories">
  <div class="cat-inline-menu-wrap">
    <button class="nav-btn nav-left" type="button" aria-label="Scroll left">‹</button>
    <div class="fade-edge fade-left" aria-hidden="true"></div>

    <ul class="cat-inline-menu" role="list" tabindex="0" aria-label="Categories list">
