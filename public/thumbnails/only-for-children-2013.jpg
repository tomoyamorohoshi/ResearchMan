<style>
/* Container principal - fundal foarte deschis */
.spotlight-search-container {
    width: 100%;
    max-width: 600px;
    background: rgba(255, 255, 255, 0.85); /* Alb foarte curat */
    backdrop-filter: blur(15px);
    -webkit-backdrop-filter: blur(15px);
    border-radius: 14px;
    padding: 10px 18px;
    box-shadow: 0 15px 35px rgba(0,0,0,0.08), 0 0 0 1px rgba(0,0,0,0.03);
    border: 1px solid rgba(255,255,255,0.6);
    transition: all 0.25s ease-in-out;
    margin: 0 auto;
}

/* Stil la Hover și Focus - se face alb solid, dar textul rămâne închis */
.spotlight-search-container:hover, 
.spotlight-search-container:focus-within {
    background: #ffffff !important; /* Alb solid la interacțiune */
    box-shadow: 0 20px 45px rgba(0,0,0,0.12);
    transform: translateY(-1px);
}

.spotlight-search-bar {
    display: flex;
    align-items: center;
    gap: 12px;
}

/* Iconița rămâne gri închis pentru contrast */
.spotlight-icon {
    color: #636366; 
}

/* Inputul - textul este întotdeauna vizibil (Negru/Gri închis) */
.spotlight-input {
    width: 100%;
    border: none !important;
    background: transparent !important;
    font-size: 17px !important;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    color: #1c1c1e !important; /* Text foarte închis la culoare */
    outline: none !important;
    padding: 8px 0 !important;
}

.spotlight-input::placeholder {
    color: #8e8e93; /* Gri pentru placeholder */
}

/* Badge-ul de shortcut */
.spotlight-shortcut {
    background: #f2f2f7;
    padding: 4px 8px;
    border-radius: 6px;
    font-size: 11px;
    color: #8e8e93;
    font-weight: 600;
    border: 1px solid rgba(0,0,0,0.05);
}

/* Fix pentru Elementor ca să nu forțeze alte culori */
.spotlight-input:focus {
    color: #1c1c1e !important;
}
</style>				</div>
				</div>
